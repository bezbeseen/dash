# Optional local overrides — copy to `.env.local` (gitignored).
# Next.js loads `.env` first, then merges `.env.local` on top.
#
# Keep DATABASE_URL / DIRECT_URL in `.env` (not only here): `npx prisma migrate`
# and other Prisma CLI commands read `.env` by default, not `.env.local`.

NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Uncomment to pin QuickBooks OAuth when testing (must match Intuit redirect list exactly):
# QUICKBOOKS_REDIRECT_URI="http://localhost:3000/api/integrations/quickbooks/callback"
